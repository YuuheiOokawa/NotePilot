generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ArticleType {
  free
  paid
}

enum ArticleStatus {
  idea
  draft
  review
  approved
  copied
  posted
  archived
}

enum ApprovalStatus {
  pending
  approved
  rejected
}

// シリーズ内での記事の役割（無料=読者獲得 / 有料=ノウハウ / まとめ=導線 / 宣伝=有料noteへの誘導）
enum SeriesRole {
  free
  paid
  summary
  promo
}

enum CheckStatus {
  not_checked
  passed
  issues_found
}

enum ClaimStatus {
  unverified
  verified
  removed
}

// 投稿準備状態。未確認情報が残っている限り ready にはならない（重要ルール）
enum ReadinessStatus {
  not_ready
  needs_review
  ready
}

model User {
  id        String   @id @default(uuid())
  name      String   @default("me")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  articles    NoteArticle[]
  ideas       ArticleIdea[]
  aiLogs      AiGenerationLog[]
  setting     Setting?
  themeGroups ThemeGroup[]

  @@map("users")
}

// テーマ別の記事シリーズ（1テーマ＝10本前後）
model ThemeGroup {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  name        String
  description String   @default("")
  createdAt   DateTime @default(now()) @map("created_at")

  user     User          @relation(fields: [userId], references: [id])
  items    SeriesItem[]
  articles NoteArticle[]

  @@map("theme_groups")
}

// シリーズ計画の1項目。記事生成前は articleId が null
model SeriesItem {
  id             String     @id @default(uuid())
  themeGroupId   String     @map("theme_group_id")
  seriesNumber   Int        @map("series_number")
  title          String
  description    String     @default("")
  role           SeriesRole @default(free)
  suggestedPrice Int?       @map("suggested_price")
  articleId      String?    @unique @map("article_id")
  createdAt      DateTime   @default(now()) @map("created_at")

  themeGroup ThemeGroup   @relation(fields: [themeGroupId], references: [id], onDelete: Cascade)
  article    NoteArticle? @relation(fields: [articleId], references: [id])

  @@map("series_items")
}

model NoteArticle {
  id            String        @id @default(uuid())
  userId        String        @map("user_id")
  ideaId        String?       @map("idea_id")
  title         String
  articleType   ArticleType   @map("article_type")
  status        ArticleStatus @default(draft)
  lead          String        @default("")
  summary       String        @default("")
  cta           String        @default("")
  hashtags      String        @default("")
  thumbnailText String        @default("") @map("thumbnail_text")

  // 販売設定（有料記事）
  price         Int?
  salesTitle    String? @map("sales_title")
  freeScopeNote String? @map("free_scope_note")
  paidValueNote String? @map("paid_value_note")
  targetReader  String? @map("target_reader")
  promoText     String? @map("promo_text")

  // シリーズ管理
  themeGroupId String?     @map("theme_group_id")
  seriesNumber Int?        @map("series_number")
  seriesRole   SeriesRole? @map("series_role")
  isPaid       Boolean     @default(false) @map("is_paid")

  // 投稿スケジュール管理（1時間3投稿まで。実投稿はユーザー承認後・手動）
  scheduledAt        DateTime? @map("scheduled_at")
  postFrequencyGroup String?   @map("post_frequency_group") // 例: "2026-07-07T10"（時間バケツ）

  // 品質チェック・ファクトチェック
  qualityScore           Int?            @map("quality_score")
  typoCheckStatus        CheckStatus     @default(not_checked) @map("typo_check_status")
  factCheckStatus        CheckStatus     @default(not_checked) @map("fact_check_status")
  hasUnverifiedClaims    Boolean         @default(false) @map("has_unverified_claims")
  reviewNotes            String          @default("") @map("review_notes")
  publishReadinessStatus ReadinessStatus @default(not_ready) @map("publish_readiness_status")

  // 将来のnote投稿連携用（予約フィールド）
  noteUrl    String?   @map("note_url")
  notePostId String?   @map("note_post_id")
  postedAt   DateTime? @map("posted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user             User              @relation(fields: [userId], references: [id])
  idea             ArticleIdea?      @relation(fields: [ideaId], references: [id])
  themeGroup       ThemeGroup?       @relation(fields: [themeGroupId], references: [id])
  seriesItem       SeriesItem?
  sections         ArticleSection[]
  approvalRequests ApprovalRequest[]
  revenueLogs      RevenueLog[]
  factClaims       FactClaim[]
  qualityChecks    QualityCheck[]

  @@map("note_articles")
}

// 要確認情報（ファクトチェック対象）。数値・法律・制度・試験・料金など
model FactClaim {
  id        String      @id @default(uuid())
  articleId String      @map("article_id")
  text      String
  category  String      @default("")
  reason    String      @default("")
  status    ClaimStatus @default(unverified)
  note      String      @default("")
  createdAt DateTime    @default(now()) @map("created_at")

  article NoteArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@map("fact_claims")
}

// 品質チェックの実行履歴（結果はJSONで保持）
model QualityCheck {
  id         String   @id @default(uuid())
  articleId  String   @map("article_id")
  score      Int
  resultJson String   @map("result_json")
  createdAt  DateTime @default(now()) @map("created_at")

  article NoteArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@map("quality_checks")
}

model ArticleIdea {
  id            String      @id @default(uuid())
  userId        String      @map("user_id")
  title         String
  description   String      @default("")
  category      String      @default("")
  suggestedType ArticleType @default(free) @map("suggested_type")
  used          Boolean     @default(false)
  createdAt     DateTime    @default(now()) @map("created_at")

  user     User          @relation(fields: [userId], references: [id])
  articles NoteArticle[]

  @@map("article_ideas")
}

model ArticleSection {
  id         String   @id @default(uuid())
  articleId  String   @map("article_id")
  orderIndex Int      @map("order_index")
  heading    String
  content    String
  isPaid     Boolean  @default(false) @map("is_paid")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  article NoteArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@map("article_sections")
}

model ApprovalRequest {
  id          String         @id @default(uuid())
  articleId   String         @map("article_id")
  status      ApprovalStatus @default(pending)
  comment     String?
  requestedAt DateTime       @default(now()) @map("requested_at")
  resolvedAt  DateTime?      @map("resolved_at")

  article NoteArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@map("approval_requests")
}

model RevenueLog {
  id        String   @id @default(uuid())
  articleId String   @map("article_id")
  date      DateTime
  count     Int      @default(1)
  amount    Int
  memo      String?
  createdAt DateTime @default(now()) @map("created_at")

  article NoteArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@map("revenue_logs")
}

model AiGenerationLog {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  articleId String?  @map("article_id")
  kind      String
  provider  String
  model     String
  prompt    String
  response  String
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("ai_generation_logs")
}

model Setting {
  id         String   @id @default(uuid())
  userId     String   @unique @map("user_id")
  profile    String   @default("")
  genres     String   @default("")
  tone       String   @default("")
  aiProvider String   @default("mock") @map("ai_provider")
  aiModel    String   @default("claude-opus-4-8") @map("ai_model")
  // 自分のnoteアカウントの公開プロフィールURL（ログイン情報は保存しない）
  noteAccountUrl String @default("") @map("note_account_url")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("settings")
}
