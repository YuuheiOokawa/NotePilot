# Neon (PostgreSQL) 接続文字列
# Neonダッシュボード > プロジェクト > Connect > Connection string をコピー
# 例: postgresql://neondb_owner:xxxxx@ep-xxxx-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
# ※ URLに「-pooler」が含まれる場合は末尾に「&pgbouncer=true」を追加してください
DATABASE_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"

# AIプロバイダ: mock (既定・APIキー不要) / anthropic
AI_PROVIDER="mock"

# AI_PROVIDER=anthropic の場合のみ必要
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-opus-4-8"

# 毎日バッチ(/api/cron/daily)の保護用シークレット（Vercelに設定推奨）
# 設定するとVercel CronのリクエストにAuthorizationヘッダとして自動付与され、それ以外の呼び出しは401になる
CRON_SECRET=""

# 毎日バッチで自動生成する記事の最大件数（既定: 3）
CRON_GENERATE_LIMIT="3"
